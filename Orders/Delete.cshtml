@model Carsweb.Models.Order

@{
    ViewData["Title"] = "Delete Order";
}

<h2>Delete Order</h2>

<div class="alert alert-warning p-3">
    <p>Are you sure you want to delete this order?</p>

    <p><strong>Customer Id:</strong> @Model.CustomerId</p>
    <p><strong>Car Id:</strong> @Model.CarId</p>
    <p><strong>Date:</strong> @Model.OrderDate.ToShortDateString()</p>
    <p><strong>Total:</strong> @Model.TotalPrice.ToString("C")</p>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>